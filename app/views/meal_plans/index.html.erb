<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1.5rem;">
  <h1 style="margin:0;">Meal Plans</h1>
  <%= link_to "Plan next week →", new_meal_plan_path, class: "btn btn--primary" %>
</div>

<% if @plans.empty? %>
  <p>No plans yet. <%= link_to "Create your first plan", new_meal_plan_path %>.</p>
<% else %>
  <% @plans.each do |plan| %>
    <div style="margin-bottom:2rem; padding-bottom:1.5rem; border-bottom:1px solid #e5e5e2;">
      <h2 style="margin-top:0;">Week of <%= plan.week_start_date.strftime("%B %-d, %Y") %></h2>
      <ul style="margin:0.5rem 0;">
        <% plan.meals.each do |meal| %>
          <li><%= meal.title %></li>
        <% end %>
      </ul>
      <p style="font-size:0.9rem; color:#555; margin:0.5rem 0;">
        Dinner nights: <%= plan.meals.sum(&:dinner_count) %>
      </p>
      <%= link_to "Edit this plan", edit_meal_plan_path(plan), class: "btn btn--sm" %>
    </div>
  <% end %>
<% end %>
