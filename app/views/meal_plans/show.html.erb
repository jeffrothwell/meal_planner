<%= link_to "← All plans", meal_plans_path, class: "btn btn--sm", style: "margin-bottom:1.25rem; display:inline-block;" %>

<h1>Week of <%= @plan.week_start_date.strftime("%B %-d, %Y") %></h1>

<ul style="list-style:none; padding:0; margin:0 0 1rem;">
  <% @plan.meals.each do |meal| %>
    <li style="padding:0.6rem 0; border-bottom:1px solid #e5e5e2;">
      <span style="font-weight:600;"><%= meal.title %></span>
      <span style="font-size:0.85rem; color:#666; margin-left:0.5rem;">
        (<%= meal.dinner_count %> <%= "night".pluralize(meal.dinner_count) %>)
      </span>
    </li>
  <% end %>
</ul>

<p style="font-size:0.95rem; color:#555;">
  Total dinner nights: <%= @plan.meals.sum(&:dinner_count) %>
</p>

<div class="form-actions">
  <%= link_to "Edit this plan", edit_meal_plan_path(@plan), class: "btn btn--primary" %>
</div>
