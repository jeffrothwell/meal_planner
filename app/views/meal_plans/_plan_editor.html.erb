<% meals_json    = meals.map     { |m| { id: m.id, title: m.title, description: m.description, dinnerCount: m.dinner_count, nutritionRating: m.nutrition_rating, kidsRating: m.kids_rating, adultRating: m.adult_rating } }.to_json %>
<% all_meals_json = all_meals.map { |m| { id: m.id, title: m.title, description: m.description, dinnerCount: m.dinner_count, nutritionRating: m.nutrition_rating, kidsRating: m.kids_rating, adultRating: m.adult_rating } }.to_json %>

<div class="plan-editor" data-controller="plan-editor"
     data-plan-editor-week-start-date-value="<%= week_start_date %>"
     data-plan-editor-meal-count-value="<%= meal_count %>"
     data-plan-editor-initial-meals-value="<%= meals_json %>"
     data-plan-editor-all-meals-value="<%= all_meals_json %>">

  <div class="plan-editor__controls">
    <label>
      Dinners per week:
      <input type="number" min="1" max="14" value="<%= meal_count %>"
             data-plan-editor-target="mealCountInput"
             data-action="change->plan-editor#onMealCountChange"
             style="width:60px; padding:0.3rem 0.5rem; border:1px solid #ccc; border-radius:4px;">
    </label>
    <button type="button" class="btn" data-action="click->plan-editor#regenerate">↺ Regenerate</button>
  </div>

  <div data-plan-editor-target="status" class="plan-editor__status"></div>

  <ul class="plan-meal-list" data-plan-editor-target="mealList"></ul>

  <div class="plan-editor__add-meal">
    <select data-plan-editor-target="addMealSelect" style="padding:0.4rem; border:1px solid #ccc; border-radius:6px;">
      <option value="">— Add a meal —</option>
    </select>
    <button type="button" class="btn" data-action="click->plan-editor#addMeal">Add</button>
  </div>

  <%= form_tag form_action, method: form_method, id: "plan-form" do %>
    <%= hidden_field_tag "week_start_date", week_start_date %>
    <input type="hidden" name="meal_count" data-plan-editor-target="mealCountHidden" value="<%= meal_count %>">
    <div data-plan-editor-target="hiddenInputs">
    </div>
    <div class="form-actions">
      <button type="button" class="btn btn--primary" data-action="click->plan-editor#save">Save plan</button>
      <%= link_to "Discard", :back, class: "btn" %>
    </div>
  <% end %>
</div>
