<% if @meal.errors.any? %>
  <div class="flash-alert">
    <% @meal.errors.full_messages.each do |message| %>
      <div><%= message %></div>
    <% end %>
  </div>
<% end %>

<%= form_with model: @meal do |f| %>
  <div class="form-group">
    <%= f.label :title %>
    <%= f.text_field :title %>
  </div>

  <div class="form-group">
    <%= f.label :description %>
    <%= f.text_area :description %>
  </div>

  <div class="form-group">
    <%= f.label :nutrition_rating, "Nutrition rating" %>
    <%= f.number_field :nutrition_rating, min: 0, max: 10 %>
    <p class="form-hint">0–10, leave blank if unknown</p>
  </div>

  <div class="form-group">
    <%= f.label :kids_rating, "Kids rating" %>
    <%= f.number_field :kids_rating, min: 0, max: 10 %>
    <p class="form-hint">0–10, leave blank if unknown</p>
  </div>

  <div class="form-group">
    <%= f.label :adult_rating, "Adult rating" %>
    <%= f.number_field :adult_rating, min: 0, max: 10 %>
    <p class="form-hint">0–10, leave blank if unknown</p>
  </div>

  <div class="form-group">
    <%= f.label :dinner_count, "Dinner nights" %>
    <%= f.number_field :dinner_count, min: 1, value: @meal.dinner_count || 1 %>
    <p class="form-hint">How many dinner nights does this meal typically cover? (e.g. Pizza = 2)</p>
  </div>

  <div class="form-group">
    <%= f.label :recipe_url, "Recipe URL" %>
    <%= f.url_field :recipe_url %>
  </div>

  <div class="form-actions">
    <%= f.submit class: "btn btn--primary" %>
  </div>
<% end %>
