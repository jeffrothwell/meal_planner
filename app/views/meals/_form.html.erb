<% if @meal.errors.any? %>
  <div class="flash-alert">
    <% @meal.errors.full_messages.each do |message| %>
      <div><%= message %></div>
    <% end %>
  </div>
<% end %>

<%= form_with model: @meal do |f| %>
  <div class="form-group">
    <%= f.label :title %>
    <%= f.text_field :title %>
  </div>

  <div class="form-group">
    <%= f.label :description %>
    <%= f.text_area :description %>
  </div>

  <div class="form-group">
    <%= f.label :nutrition_rating, "Nutrition rating" %>
    <%= f.number_field :nutrition_rating, min: 0, max: 10 %>
    <p class="form-hint">0–10, leave blank if unknown</p>
  </div>

  <div class="form-group">
    <%= f.label :kids_rating, "Kids rating" %>
    <%= f.number_field :kids_rating, min: 0, max: 10 %>
    <p class="form-hint">0–10, leave blank if unknown</p>
  </div>

  <div class="form-group">
    <%= f.label :adult_rating, "Adult rating" %>
    <%= f.number_field :adult_rating, min: 0, max: 10 %>
    <p class="form-hint">0–10, leave blank if unknown</p>
  </div>

  <div class="form-group">
    <%= f.label :dinner_count, "Dinner nights" %>
    <%= f.number_field :dinner_count, min: 1, value: @meal.dinner_count || 1 %>
    <p class="form-hint">How many dinner nights does this meal typically cover? (e.g. Pizza = 2)</p>
  </div>

  <div class="form-group">
    <%= f.label :variety_group, "Variety group" %>
    <% existing_groups = Meal.distinct.where.not(variety_group: nil).order(:variety_group).pluck(:variety_group) %>
    <%= f.text_field :variety_group, list: "variety-group-options", placeholder: "e.g. soup, mexican, burger" %>
    <datalist id="variety-group-options">
      <% existing_groups.each do |group| %>
        <option value="<%= group %>">
      <% end %>
    </datalist>
    <p class="form-hint">Meals in the same group won't both appear in the same week's suggestions. Leave blank for no restriction.</p>
  </div>

  <div class="form-group">
    <%= f.label :seasonal_preference, "Seasonal preference" %>
    <%= f.select :seasonal_preference,
          Meal::SEASONAL_PREFERENCE_LABELS.map { |value, label| [ label, value ] } %>
    <p class="form-hint">Limits when this meal is suggested during plan generation.</p>
  </div>

  <div class="form-group">
    <%= f.label :recipe_url, "Recipe URL" %>
    <%= f.url_field :recipe_url %>
  </div>

  <div class="form-actions">
    <%= f.submit class: "btn btn--primary" %>
  </div>
<% end %>
